{#
 # Marketplace - Repository tab.
 # Params: repositories (MarketplaceRepositoryInterface[]), catalog (MarketplaceListing[])
 #}
<p class="light">
    {{ "Every repository registered through MarketplaceRepositoryInterface is listed below with the packages it currently has available to pull. The Local Repository reads .s7pkg files from a folder on this server; Commerce24 reads its catalog live over the network once configured on the Commerce settings tab."|t('site7-studio') }}
</p>

{% for repository in repositories %}
    {% set listings = repository.listAvailablePackages() %}
    <section class="site7-detail-section" style="margin-bottom: 24px;">
        <h2>{{ repository.getName() }}</h2>
        {% if listings|length %}
            <table class="data fullwidth">
                <thead>
                    <tr>
                        <th scope="col">{{ "Package"|t('site7-studio') }}</th>
                        <th scope="col">{{ "Type"|t('site7-studio') }}</th>
                        <th scope="col">{{ "Version"|t('site7-studio') }}</th>
                        <th scope="col">{{ "File"|t('site7-studio') }}</th>
                        <th scope="col">{{ "Action"|t('site7-studio') }}</th>
                    </tr>
                </thead>
                <tbody>
                    {% for listing in listings %}
                        <tr>
                            <th scope="row">{{ listing.handle }}</th>
                            <td>{{ listing.type|title }}</td>
                            <td>v{{ listing.version }}</td>
                            <td class="light">{{ listing.fileName }}</td>
                            <td>
                                <form method="post" accept-charset="UTF-8">
                                    {{ csrfInput() }}
                                    <input type="hidden" name="action" value="site7-studio/marketplace/install-from-repository">
                                    <input type="hidden" name="repositoryHandle" value="{{ repository.getHandle() }}">
                                    <input type="hidden" name="handle" value="{{ listing.handle }}">
                                    <button type="submit" class="btn small"
                                        onclick="return confirm('Install {{ listing.handle|e('js') }} v{{ listing.version|e('js') }} from {{ repository.getName()|e('js') }}? If it already exists locally with different content, this will overwrite it.');">
                                        {{ "Install"|t('site7-studio') }}
                                    </button>
                                </form>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        {% else %}
            {% include "site7-studio/_components/empty-state" with {
                message: 'No packages available from ' ~ repository.getName() ~ ' yet.',
                subtext: 'Export a package from the Export tab and copy it into storage/site7-studio/marketplace-repo/ (Local), or publish it to Commerce24 from the Publishing wizard, to make it pullable from here.',
                icon: '🗄️'
            } only %}
        {% endif %}
    </section>
{% endfor %}
