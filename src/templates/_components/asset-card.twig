{#
 # Asset Card Component
 #
 # Params:
 #   name        (string, required) – card title
 #   description (string, required) – card description
 #   category    (string, optional) – category label
 #   status      (string, optional) – Active, Draft, Coming Soon
 #   image       (string, optional) – image URL
 #}
<div class="site7-card">
    {% if status is defined and status %}
        {% set badgeClass = status|lower == 'active' ? 'site7-badge--active' :
                            (status|lower == 'draft' ? 'site7-badge--draft' : 'site7-badge--coming-soon') %}
        <span class="site7-badge {{ badgeClass }}">{{ status }}</span>
    {% endif %}

    <div class="site7-card-image">
        {% if image is defined and image %}
            <img src="{{ image }}" alt="{{ name }}">
        {% else %}
            <span>Preview</span>
        {% endif %}
    </div>

    <div class="site7-card-body">
        {% if category is defined and category %}
            <div class="site7-card-category">{{ category }}</div>
        {% endif %}
        <h4 class="site7-card-title">{{ name }}</h4>
        <p class="site7-card-description">{{ description }}</p>
    </div>
</div>
