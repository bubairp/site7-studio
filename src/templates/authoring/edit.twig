{% extends "_layouts/cp" %}
{% set selectedSubnavItem = "library" %}
{% set authoringStatusColors = {draft: 'gray', preview: 'blue', testing: 'amber', published: 'teal', deprecated: 'orange', archived: 'red'} %}
{% set authoringStatusColor = authoringStatusColors[package.authoringStatus] ?? 'gray' %}
{% set typeLabel = package.type == 'starter-kit' ? 'Starter Kits' : package.type|title ~ 's' %}
{% set crumbs = [
    {label: 'Library'|t('site7-studio'), url: 'site7-studio/library'},
    {label: typeLabel, url: 'site7-studio/library?type=' ~ package.type},
    {label: package.name, url: 'site7-studio/library/package/' ~ package.handle},
    {label: 'Edit'|t('site7-studio'), current: true},
] %}

{% block pageTitle %}
    <div class="flex flex-nowrap flex-gap-s" style="align-items: center;">
        <h1 id="page-heading" class="screen-title">{{ "Edit"|t('site7-studio') }}: {{ package.name }}</h1>
        <span class="status-label {{ authoringStatusColor }}">
            <span class="status {{ authoringStatusColor }}"></span>
            <span class="status-label-text">{{ package.authoringStatus|default('draft')|title }}</span>
        </span>
    </div>
{% endblock %}

{% block actionButton %}
    {% if currentUser.can('publishPackages') %}
        <a href="{{ url('site7-studio/packages/' ~ package.handle ~ '/publish') }}" class="btn submit">{{ "Publish"|t('site7-studio') }}</a>
    {% endif %}
    <a href="{{ url('site7-studio/library/package/' ~ package.handle) }}" class="btn">{{ "View in Library"|t('site7-studio') }}</a>
{% endblock %}

{% set packageTags = package.tags is iterable ? package.tags|join(', ') : package.tags %}

{% block content %}
    <form method="post" accept-charset="UTF-8">
        {{ csrfInput() }}
        {{ redirectInput('site7-studio/packages/' ~ package.handle ~ '/edit') }}
        <input type="hidden" name="action" value="site7-studio/package-authoring/save">
        <input type="hidden" name="handle" value="{{ package.handle }}">

        <section class="site7-detail-section">
            <h2>{{ "General"|t('site7-studio') }}</h2>
            <div class="field" style="margin-bottom: 16px;">
                <div class="heading"><label for="site7pe-name">{{ "Name"|t('site7-studio') }}</label></div>
                <div class="input"><input type="text" id="site7pe-name" name="name" class="text fullwidth" value="{{ package.name }}" required></div>
            </div>
            <div class="field" style="margin-bottom: 16px;">
                <div class="heading"><label for="site7pe-description">{{ "Description"|t('site7-studio') }}</label></div>
                <div class="input"><textarea id="site7pe-description" name="description" class="text fullwidth" rows="3">{{ package.description }}</textarea></div>
            </div>
            <div class="flex flex-gap-m" style="margin-bottom: 16px;">
                <div class="field flex-grow">
                    <div class="heading"><label for="site7pe-category">{{ "Category"|t('site7-studio') }}</label></div>
                    <div class="input"><input type="text" id="site7pe-category" name="category" class="text fullwidth" value="{{ package.category }}"></div>
                </div>
                <div class="field flex-grow">
                    <div class="heading"><label for="site7pe-tags">{{ "Tags"|t('site7-studio') }}</label></div>
                    <div class="input"><input type="text" id="site7pe-tags" name="tags" class="text fullwidth" value="{{ packageTags }}" placeholder="Comma-separated"></div>
                </div>
            </div>
            <div class="flex flex-gap-m">
                <div class="field flex-grow">
                    <div class="heading"><label for="site7pe-version">{{ "Version"|t('site7-studio') }}</label></div>
                    <div class="input"><input type="text" id="site7pe-version" name="version" class="text fullwidth" value="{{ package.version }}"></div>
                </div>
                <div class="field flex-grow">
                    <div class="heading"><label for="site7pe-author">{{ "Author"|t('site7-studio') }}</label></div>
                    <div class="input"><input type="text" id="site7pe-author" name="author" class="text fullwidth" value="{{ package.author }}"></div>
                </div>
            </div>
            <div style="margin-top: 16px;">
                <button type="submit" class="btn submit">{{ "Save"|t('site7-studio') }}</button>
            </div>
        </section>
    </form>

    <hr>

    <section class="site7-detail-section">
        <h2>{{ "Preview Image"|t('site7-studio') }}</h2>
        <p class="light">{{ "Shown as this package's thumbnail throughout the Library."|t('site7-studio') }}</p>
        <div class="flex flex-nowrap flex-gap-m" style="align-items: flex-start;">
            {% if previewImageUrl %}
                <img src="{{ previewImageUrl }}" alt="" style="width: 160px; height: 100px; object-fit: cover; border-radius: 4px; border: 1px solid var(--hairline-color);">
            {% else %}
                <div class="light" style="width: 160px; height: 100px; display: flex; align-items: center; justify-content: center; border: 1px dashed var(--hairline-color); border-radius: 4px;">{{ "No image"|t('site7-studio') }}</div>
            {% endif %}
            <form method="post" accept-charset="UTF-8" enctype="multipart/form-data">
                {{ csrfInput() }}
                {{ redirectInput('site7-studio/packages/' ~ package.handle ~ '/edit') }}
                <input type="hidden" name="action" value="site7-studio/package-authoring/upload-preview-image">
                <input type="hidden" name="handle" value="{{ package.handle }}">
                <div class="field" style="margin-bottom: 8px;">
                    <div class="input"><input type="file" name="previewImage" accept="image/png,image/jpeg,image/gif,image/webp" required></div>
                </div>
                <button type="submit" class="btn submit">{{ "Upload"|t('site7-studio') }}</button>
            </form>
        </div>
    </section>

    <hr>

    <section class="site7-detail-section">
        <h2>{{ "Package Builder"|t('site7-studio') }}</h2>
        {% if package.type == 'section' %}
            <p class="light">{{ "Fields are all plain text for now. Each row becomes a real Craft field when this Section is installed."|t('site7-studio') }}</p>
            <form method="post" accept-charset="UTF-8" id="site7-section-builder-form">
                {{ csrfInput() }}
                {{ redirectInput('site7-studio/packages/' ~ package.handle ~ '/edit') }}
                <input type="hidden" name="action" value="site7-studio/package-authoring/save-fields">
                <input type="hidden" name="handle" value="{{ package.handle }}">

                <table class="data fullwidth" id="site7-section-fields-table">
                    <thead>
                        <tr>
                            <th>{{ "Handle"|t('site7-studio') }}</th>
                            <th>{{ "Name"|t('site7-studio') }}</th>
                            <th>{{ "Instructions"|t('site7-studio') }}</th>
                            <th>{{ "Demo Value"|t('site7-studio') }}</th>
                            <th class="thin"></th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for field in sectionFields %}
                            <tr>
                                <td><input type="text" name="fields[{{ loop.index0 }}][handle]" class="text code" value="{{ field.handle }}"></td>
                                <td><input type="text" name="fields[{{ loop.index0 }}][name]" class="text" value="{{ field.name }}"></td>
                                <td><input type="text" name="fields[{{ loop.index0 }}][instructions]" class="text fullwidth" value="{{ field.instructions }}"></td>
                                <td><input type="text" name="fields[{{ loop.index0 }}][demoValue]" class="text fullwidth" value="{{ field.demoValue }}"></td>
                                <td><button type="button" class="btn delete icon site7-remove-field-row" title="{{ 'Remove'|t('site7-studio') }}"></button></td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>

                <div style="margin-top: 12px; display: flex; justify-content: space-between; align-items: center;">
                    <button type="button" class="btn" id="site7-add-field-row">{{ "+ Add Field"|t('site7-studio') }}</button>
                    <button type="submit" class="btn submit">{{ "Save Package Builder"|t('site7-studio') }}</button>
                </div>
            </form>
        {% elseif package.type == 'pattern' %}
            <p class="light">{{ "Drag Sections from the library on the left into the canvas, reorder them, then select a card to set its Default Values (these belong to this Pattern only - the Section package itself is never changed)."|t('site7-studio') }}</p>
            <form method="post" accept-charset="UTF-8" id="site7-pattern-builder-form">
                {{ csrfInput() }}
                {{ redirectInput('site7-studio/packages/' ~ package.handle ~ '/edit') }}
                <input type="hidden" name="action" value="site7-studio/package-authoring/save-pattern">
                <input type="hidden" name="handle" value="{{ package.handle }}">
                <input type="hidden" name="composition" id="site7-pb-composition-input">

                <div id="site7-pattern-builder"
                     data-available-sections="{{ availableSections|json_encode|escape('html_attr') }}"
                     data-composition="{{ patternComposition|json_encode|escape('html_attr') }}">
                    <div class="site7-pb-column site7-pb-sidebar">
                        <h3>{{ "Available Sections"|t('site7-studio') }}</h3>
                        <input type="text" id="site7-pb-search" class="text fullwidth" placeholder="{{ 'Search Sections...'|t('site7-studio') }}">
                        <div id="site7-pb-library"></div>
                    </div>
                    <div class="site7-pb-column site7-pb-canvas">
                        <h3>{{ "Pattern Canvas"|t('site7-studio') }}</h3>
                        <div id="site7-pb-canvas-list" class="site7-pb-dropzone"></div>
                    </div>
                    <div class="site7-pb-column site7-pb-properties">
                        <h3>{{ "Section Properties"|t('site7-studio') }}</h3>
                        <div id="site7-pb-properties-body">
                            <p class="light">{{ "Select a Section in the canvas to edit its Default Values."|t('site7-studio') }}</p>
                        </div>
                    </div>
                </div>

                <div style="margin-top: 12px; text-align: right;">
                    <button type="submit" class="btn submit">{{ "Save Pattern"|t('site7-studio') }}</button>
                </div>
            </form>
        {% elseif package.type == 'template' %}
            <p class="light">{{ "Drag Sections and Patterns from the library on the left into the canvas, reorder them, then select a Section to set its Default Values (a Pattern's own content is configured in the Pattern's own editor - a Template only references it)."|t('site7-studio') }}</p>
            <p class="light"><em>{{ "Install order is always Patterns, then Sections, regardless of how they're arranged here."|t('site7-studio') }}</em></p>
            <form method="post" accept-charset="UTF-8" id="site7-template-builder-form">
                {{ csrfInput() }}
                {{ redirectInput('site7-studio/packages/' ~ package.handle ~ '/edit') }}
                <input type="hidden" name="action" value="site7-studio/package-authoring/save-template">
                <input type="hidden" name="handle" value="{{ package.handle }}">
                <input type="hidden" name="composition" id="site7-tb-composition-input">

                <div id="site7-template-builder"
                     data-available-items="{{ availableTemplateItems|json_encode|escape('html_attr') }}"
                     data-composition="{{ templateComposition|json_encode|escape('html_attr') }}">
                    <div class="site7-pb-column site7-pb-sidebar">
                        <h3>{{ "Available Packages"|t('site7-studio') }}</h3>
                        <input type="text" id="site7-tb-search" class="text fullwidth" placeholder="{{ 'Search Sections & Patterns...'|t('site7-studio') }}">
                        <div class="site7-tb-filter" id="site7-tb-filter">
                            <button type="button" class="btn small active" data-filter="all">{{ "All"|t('site7-studio') }}</button>
                            <button type="button" class="btn small" data-filter="section">{{ "Sections"|t('site7-studio') }}</button>
                            <button type="button" class="btn small" data-filter="pattern">{{ "Patterns"|t('site7-studio') }}</button>
                        </div>
                        <div id="site7-tb-library"></div>
                    </div>
                    <div class="site7-pb-column site7-pb-canvas">
                        <h3>{{ "Template Canvas"|t('site7-studio') }}</h3>
                        <div id="site7-tb-canvas-list" class="site7-pb-dropzone"></div>
                    </div>
                    <div class="site7-pb-column site7-pb-properties">
                        <h3>{{ "Properties"|t('site7-studio') }}</h3>
                        <div id="site7-tb-properties-body">
                            <p class="light">{{ "Select a Section in the canvas to edit its Default Values."|t('site7-studio') }}</p>
                        </div>
                    </div>
                </div>

                <div style="margin-top: 12px; text-align: right;">
                    <button type="submit" class="btn submit">{{ "Save Template"|t('site7-studio') }}</button>
                </div>
            </form>
        {% elseif package.type == 'starter-kit' %}
            <p class="light">{{ "Drag Templates from the library on the left into the canvas to add Pages, reorder them, then select a Page to set its Title, Slug, and Entry Type (a Template's own content is never changed - a Starter Kit only references it)."|t('site7-studio') }}</p>
            <form method="post" accept-charset="UTF-8" id="site7-starter-kit-builder-form">
                {{ csrfInput() }}
                {{ redirectInput('site7-studio/packages/' ~ package.handle ~ '/edit') }}
                <input type="hidden" name="action" value="site7-studio/package-authoring/save-starter-kit">
                <input type="hidden" name="handle" value="{{ package.handle }}">
                <input type="hidden" name="composition" id="site7-sk-composition-input">

                <div id="site7-starter-kit-builder"
                     data-available-templates="{{ availableTemplates|json_encode|escape('html_attr') }}"
                     data-eligible-entry-types="{{ eligibleEntryTypes|json_encode|escape('html_attr') }}"
                     data-composition="{{ starterKitComposition|json_encode|escape('html_attr') }}">
                    <div class="site7-pb-column site7-pb-sidebar">
                        <h3>{{ "Available Templates"|t('site7-studio') }}</h3>
                        <input type="text" id="site7-sk-search" class="text fullwidth" placeholder="{{ 'Search Templates...'|t('site7-studio') }}">
                        <div id="site7-sk-library"></div>
                    </div>
                    <div class="site7-pb-column site7-pb-canvas">
                        <h3>{{ "Starter Kit Canvas"|t('site7-studio') }}</h3>
                        <div id="site7-sk-canvas-list" class="site7-pb-dropzone"></div>
                    </div>
                    <div class="site7-pb-column site7-pb-properties">
                        <h3>{{ "Page Properties"|t('site7-studio') }}</h3>
                        <div id="site7-sk-properties-body">
                            <p class="light">{{ "Select a Page in the canvas to edit its Title, Slug, and Entry Type."|t('site7-studio') }}</p>
                        </div>
                    </div>
                </div>

                <div style="margin-top: 12px; text-align: right;">
                    <button type="submit" class="btn submit">{{ "Save Starter Kit"|t('site7-studio') }}</button>
                </div>
            </form>
        {% else %}
            <p class="light">{{ "The {type} Builder is coming in a later increment - for now, {type} packages are configured by hand-editing their manifest and package files."|t('site7-studio', {type: package.type|title}) }}</p>
        {% endif %}
    </section>

    <hr>

    <section class="site7-detail-section">
        <h2>{{ "Package Information"|t('site7-studio') }}</h2>
        <div class="meta">
            <div class="field">
                <div class="heading"><label>{{ "Handle"|t('site7-studio') }}</label></div>
                <div class="input"><code>{{ package.handle }}</code></div>
            </div>
            <div class="field">
                <div class="heading"><label>{{ "Package Type"|t('site7-studio') }}</label></div>
                <div class="input">{{ package.type|title }}</div>
            </div>
            <div class="field">
                <div class="heading"><label>{{ "Install Status"|t('site7-studio') }}</label></div>
                <div class="input">{{ package.status|title }}</div>
            </div>
            <div class="field">
                <div class="heading"><label>{{ "Created"|t('site7-studio') }}</label></div>
                <div class="input">{{ package.dateCreated|datetime('short') }}</div>
            </div>
            <div class="field">
                <div class="heading"><label>{{ "Last Updated"|t('site7-studio') }}</label></div>
                <div class="input">{{ package.dateUpdated|datetime('short') }}</div>
            </div>
        </div>
        <form method="post" accept-charset="UTF-8" style="margin-top: 16px;">
            {{ csrfInput() }}
            {{ redirectInput('site7-studio/library') }}
            <input type="hidden" name="action" value="site7-studio/package-action/delete">
            <input type="hidden" name="handle" value="{{ package.handle }}">
            <button type="button" class="btn delete"
                onclick="if(confirm('Permanently delete {{ package.name|e('js') }}? This deletes its entire folder from disk and cannot be undone.')) { this.closest('form').submit(); }"
            >{{ "Delete Package"|t('site7-studio') }}</button>
        </form>
    </section>
{% endblock %}
