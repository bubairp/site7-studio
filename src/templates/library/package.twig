{% extends "_layouts/cp" %}
{% set selectedSubnavItem = "library" %}
{% set statusColors = {available: 'gray', installed: 'blue', enabled: 'teal', disabled: 'red'} %}
{% set statusColor = statusColors[package.status] ?? 'gray' %}
{% set typeLabel = package.type == 'starter-kit' ? 'Starter Kits' : package.type|title ~ 's' %}
{% set crumbs = [
    {label: 'Library'|t('site7-studio'), url: 'site7-studio/library'},
    {label: typeLabel, url: 'site7-studio/library?type=' ~ package.type},
    {label: package.name, current: true},
] %}

{% block pageTitle %}
    <div class="flex flex-nowrap flex-gap-s" style="align-items: center;">
        <h1 id="page-heading" class="screen-title">{{ package.name }}</h1>
        <span class="status-label {{ statusColor }}">
            <span class="status {{ statusColor }}"></span>
            <span class="status-label-text">{{ package.status|title }}</span>
        </span>
    </div>
{% endblock %}

{% set isDevMode = craft.app.config.general.devMode %}
{% set isOwnTemplate = package.type == 'template' and package.creatorId and package.creatorId == currentUser.id %}
{% set canManageThis = isDevMode or isOwnTemplate %}

{% block actionButton %}
    <div class="flex">
        {% if canManageThis %}
            <a href="{{ url('site7-studio/packages/' ~ package.handle ~ '/edit') }}" class="btn">{{ "Edit"|t('site7-studio') }}</a>
        {% endif %}

        {# Preview button is ALWAYS visible, regardless of status #}
        <button type="button" class="btn" id="site7-preview-btn"
            data-handle="{{ package.handle }}"
            data-name="{{ package.name }}"
            data-has-template="{{ hasPreviewTemplate ? '1' : '0' }}"
            data-has-image="{{ hasPreviewImage ? '1' : '0' }}"
            data-render-url="{{ url('site7-studio/library/package/' ~ package.handle ~ '/render-preview') }}"
            data-image-url="{{ url('site7-studio/library/package/' ~ package.handle ~ '/preview-image') }}"
        >{{ "Preview"|t('site7-studio') }}</button>

        {% if package.type|lower == 'template' and package.status == 'enabled' %}
            <button type="button" class="btn submit" id="site7-create-from-template-btn" data-handle="{{ package.handle }}">{{ "Create Page from Template"|t('site7-studio') }}</button>
        {% endif %}

        {% if package.type|lower == 'starter-kit' and package.status == 'enabled' %}
            <button type="button" class="btn submit" id="site7-install-starter-kit-btn" data-handle="{{ package.handle }}">{{ "Install Starter Kit"|t('site7-studio') }}</button>
        {% endif %}

        {% if not isSetupComplete %}
            <a href="{{ url('site7-studio/setup') }}" class="btn submit">{{ "Complete Setup to Install"|t('site7-studio') }}</a>
        {% else %}
            {% if package.status == 'available' %}
                <form method="post" accept-charset="UTF-8">
                    {{ csrfInput() }}
                    {{ redirectInput('site7-studio/library/package/' ~ package.handle) }}
                    <input type="hidden" name="action" value="site7-studio/package-action/install">
                    <input type="hidden" name="handle" value="{{ package.handle }}">
                    <button type="submit" class="btn submit">{{ "Install Package"|t('site7-studio') }}</button>
                </form>
            {% else %}
                {% if package.status == 'installed' or package.status == 'disabled' %}
                    <form method="post" accept-charset="UTF-8">
                        {{ csrfInput() }}
                        {{ redirectInput('site7-studio/library/package/' ~ package.handle) }}
                        <input type="hidden" name="action" value="site7-studio/package-action/enable">
                        <input type="hidden" name="handle" value="{{ package.handle }}">
                        <button type="submit" class="btn submit">{{ "Enable"|t('site7-studio') }}</button>
                    </form>
                {% endif %}

                {% if package.status == 'enabled' %}
                    <form method="post" accept-charset="UTF-8" id="disableForm">
                        {{ csrfInput() }}
                        {{ redirectInput('site7-studio/library/package/' ~ package.handle) }}
                        <input type="hidden" name="action" value="site7-studio/package-action/disable">
                        <input type="hidden" name="handle" value="{{ package.handle }}">
                        <button type="button" class="btn {{ usage is not empty ? 'disabled' : '' }}"
                            {% if usage is not empty %}
                                disabled title="{{ 'Cannot disable while in use'|t('site7-studio') }}"
                            {% else %}
                                onclick="if(confirm('Are you sure you want to disable this package? It will no longer be available to content editors.')) { this.closest('form').submit(); }"
                            {% endif %}
                        >{{ "Disable"|t('site7-studio') }}</button>
                    </form>
                {% endif %}

                <form method="post" accept-charset="UTF-8" id="removeForm">
                    {{ csrfInput() }}
                    {{ redirectInput('site7-studio/library/package/' ~ package.handle) }}
                    <input type="hidden" name="action" value="site7-studio/package-action/remove">
                    <input type="hidden" name="handle" value="{{ package.handle }}">
                    <button type="button" class="btn delete icon {{ usage is not empty ? 'disabled' : '' }}"
                        {% if usage is not empty %}
                            disabled title="{{ 'Cannot remove while in use'|t('site7-studio') }}"
                        {% else %}
                            onclick="if(confirm('Are you sure you want to remove this package? This will delete all generated fields, entry types, and templates.')) { this.closest('form').submit(); }"
                        {% endif %}
                    >{{ "Remove"|t('site7-studio') }}</button>
                </form>
            {% endif %}
        {% endif %}

        {% if canManageThis %}
            <form method="post" accept-charset="UTF-8" id="deleteForm">
                {{ csrfInput() }}
                {{ redirectInput('site7-studio/library/package/' ~ package.handle) }}
                <input type="hidden" name="action" value="site7-studio/package-action/delete">
                <input type="hidden" name="handle" value="{{ package.handle }}">
                <button type="button" class="btn delete icon {{ usage is not empty ? 'disabled' : '' }}"
                    {% if usage is not empty %}
                        disabled title="{{ 'Cannot delete while in use'|t('site7-studio') }}"
                    {% else %}
                        onclick="if(confirm('Permanently delete this package? This deletes its entire folder from disk and cannot be undone.')) { this.closest('form').submit(); }"
                    {% endif %}
                >{{ "Delete"|t('site7-studio') }}</button>
            </form>
        {% endif %}
    </div>
{% endblock %}

{% set authoringStatusColors = {draft: 'gray', preview: 'blue', testing: 'amber', published: 'teal', deprecated: 'orange', archived: 'red'} %}
{% set authoringStatusColor = authoringStatusColors[package.authoringStatus] ?? 'gray' %}

{% block details %}
    <div class="meta">
        <div class="field">
            <div class="heading"><label>{{ "Authoring Status"|t('site7-studio') }}</label></div>
            <div class="input">
                <span class="status-label {{ authoringStatusColor }}">
                    <span class="status {{ authoringStatusColor }}"></span>
                    <span class="status-label-text">{{ package.authoringStatus|default('draft')|title }}</span>
                </span>
            </div>
        </div>
        <div class="field">
            <div class="heading"><label>{{ "Author"|t('site7-studio') }}</label></div>
            <div class="input">{{ package.author|default('Unknown') }}</div>
        </div>
        <div class="field">
            <div class="heading"><label>{{ "Version"|t('site7-studio') }}</label></div>
            <div class="input">{{ package.version }}</div>
        </div>
        <div class="field">
            <div class="heading"><label>{{ "Package Type"|t('site7-studio') }}</label></div>
            <div class="input">{{ package.type|title }}</div>
        </div>
        {% if package.category %}
            <div class="field">
                <div class="heading"><label>{{ "Category"|t('site7-studio') }}</label></div>
                <div class="input">{{ package.category }}</div>
            </div>
        {% endif %}
        {% set packageTags = package.tags is iterable ? package.tags : (package.tags|default('')|split(',')) %}
        {% if packageTags|length %}
            <div class="field">
                <div class="heading"><label>{{ "Tags"|t('site7-studio') }}</label></div>
                <div class="input">{{ packageTags|join(', ') }}</div>
            </div>
        {% endif %}
        <div class="field">
            <div class="heading"><label>{{ "Required Craft Version"|t('site7-studio') }}</label></div>
            <div class="input">{{ package.requiredCraftVersion|default('Not specified') }}</div>
        </div>
        <div class="field">
            <div class="heading"><label>{{ "Required Site7 Version"|t('site7-studio') }}</label></div>
            <div class="input">{{ package.minimumStudioVersion|default('Not specified') }}</div>
        </div>
    </div>
{% endblock %}

{% block content %}
    <section class="site7-detail-section">
        <h2>{{ "Overview"|t('site7-studio') }}</h2>
        <div class="flex flex-nowrap flex-gap-l">
            {% if hasPreviewImage %}
                <div class="site7-detail-thumb">
                    <img src="{{ url('site7-studio/library/package/' ~ package.handle ~ '/preview-image') }}" alt="{{ package.name }}">
                </div>
            {% endif %}
            <p class="readable">{{ package.description|default('No description provided.') }}</p>
        </div>
    </section>

    {% if package.type|lower == 'starter-kit' %}
        {% set manifest = package.getManifest() %}
        <hr>
        <section class="site7-detail-section">
            <h2>{{ "Starter Kit Composition"|t('site7-studio') }}</h2>
            <div class="meta">
                <div class="field">
                    <div class="heading"><label>{{ "Included Templates"|t('site7-studio') }}</label></div>
                    <div class="input">
                        {% if manifest and manifest.requires.templates is defined and manifest.requires.templates|length %}
                            {{ manifest.requires.templates|map(t => t|title)|join(', ') }}
                        {% else %}
                            <span class="light">{{ "None"|t('site7-studio') }}</span>
                        {% endif %}
                    </div>
                </div>
            </div>
            {% if manifest and manifest.pages is defined and manifest.pages|length %}
                <h3>{{ "Pages"|t('site7-studio') }}</h3>
                <table class="data fullwidth">
                    <thead>
                        <tr>
                            <th>{{ "Title"|t('site7-studio') }}</th>
                            <th>{{ "Section"|t('site7-studio') }}</th>
                            <th>{{ "Template"|t('site7-studio') }}</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for page in manifest.pages %}
                            <tr>
                                <td>{{ page.title }}</td>
                                <td class="light">{{ page.sectionHandle|default('—') }}</td>
                                <td class="light">{{ page.templateHandle|default('—') }}</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            {% endif %}
        </section>
    {% endif %}

    {% if package.type|lower == 'pattern' or package.type|lower == 'template' %}
        {% set manifest = package.getManifest() %}
        <hr>
        <section class="site7-detail-section">
            <h2>{{ package.type|title }} {{ "Composition"|t('site7-studio') }}</h2>
            <div class="meta">
                {% if package.type|lower == 'template' %}
                    <div class="field">
                        <div class="heading"><label>{{ "Included Patterns"|t('site7-studio') }}</label></div>
                        <div class="input">
                            {% if manifest and manifest.requires.patterns is defined and manifest.requires.patterns|length %}
                                {{ manifest.requires.patterns|map(p => p|title)|join(', ') }}
                            {% else %}
                                <span class="light">{{ "None"|t('site7-studio') }}</span>
                            {% endif %}
                        </div>
                    </div>
                {% endif %}
                <div class="field">
                    <div class="heading"><label>{{ "Included Sections"|t('site7-studio') }}</label></div>
                    <div class="input">
                        {% if manifest and manifest.requires.sections is defined and manifest.requires.sections|length %}
                            {{ manifest.requires.sections|map(s => s|title)|join(', ') }}
                        {% else %}
                            <span class="light">{{ "None"|t('site7-studio') }}</span>
                        {% endif %}
                    </div>
                </div>
            </div>
            {% if manifest and manifest.demoContent is defined and manifest.demoContent %}
                <h3>{{ "Demo Content Definition"|t('site7-studio') }}</h3>
                <pre class="code">{{ manifest.demoContent|json_encode(constant('JSON_PRETTY_PRINT')) }}</pre>
            {% endif %}
        </section>
    {% endif %}

    <hr>
    <section class="site7-detail-section">
        <h2>{{ "Usage"|t('site7-studio') }}</h2>
        {% if usage is defined and usage is not empty %}
            <div class="site7-notice site7-notice--warning">
                <strong>{{ "In Use:"|t('site7-studio') }}</strong> {{ "This package cannot be disabled or removed while it is being used in content."|t('site7-studio') }}
            </div>
            <table class="data fullwidth">
                <thead>
                    <tr>
                        <th>{{ "Entry Title"|t('site7-studio') }}</th>
                        <th class="thin">{{ "Action"|t('site7-studio') }}</th>
                    </tr>
                </thead>
                <tbody>
                    {% for entry in usage %}
                        <tr>
                            <td>{{ entry.title }} <span class="light">({{ entry.section.name|default('Unknown Section') }})</span></td>
                            <td><a href="{{ entry.cpEditUrl }}" target="_blank">{{ "Edit"|t('site7-studio') }} &rarr;</a></td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        {% else %}
            <p class="light">{{ "This package is not currently used in any entries."|t('site7-studio') }}</p>
        {% endif %}
    </section>
{% endblock %}
