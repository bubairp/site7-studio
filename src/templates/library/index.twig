{% extends "_layouts/cp" %}
{% set title = "Library" %}
{% set selectedSubnavItem = "library" %}

{% block sidebar %}
    {% include "site7-studio/_components/sidebar" with { selectedItem: 'sections' } only %}
{% endblock %}

{% block toolbar %}
    <div class="flex flex-nowrap align-center" style="width: 100%;">
        <div class="flex-grow">
            <div class="texticon search icon clearable">
                {{ tag('input', {
                    id: 'site7-search-input',
                    type: 'text',
                    class: 'text fullwidth',
                    placeholder: 'Search sections...',
                    'aria-label': 'Search',
                }) }}
                <div class="clear hidden" title="Clear"></div>
            </div>
        </div>
        <div class="btn menubtn" data-icon="filter">{{ "Filter"|t('site7-studio') }}</div>
    </div>
{% endblock %}

{% block content %}
    {% if not isSetupComplete %}
        <div style="background: #fff3cd; color: #856404; padding: 15px; border-radius: 4px; border: 1px solid #ffeeba; margin-bottom: 20px;">
            <strong>Warning:</strong> You must complete the First-Time Setup Wizard before you can install packages. 
            <a href="{{ url('site7-studio/setup') }}" style="margin-left: 10px; text-decoration: underline; font-weight: bold;">Complete Setup &rarr;</a>
        </div>
    {% endif %}

    <div class="site7-card-grid">
        {% for package in packages %}
            {% include "site7-studio/_components/asset-card" with { 
                package: package,
                isSetupComplete: isSetupComplete
            } only %}
        {% else %}
            {% include "site7-studio/_components/empty-state" with { 
                title: 'No packages found',
                message: 'No packages were discovered in the configured sources.',
                icon: 'library'
            } only %}
        {% endfor %}
    </div>

    {# 
    {% include "site7-studio/_components/empty-state" with { 
        message: 'No Assets Found',
        subtext: 'Try adjusting your filters or search query.',
        icon: '🔍'
    } only %} 
    #}
{% endblock %}
