{% extends "_layouts/cp" %}
{% set selectedSubnavItem = "library" %}

{% block sidebar %}
    {% include "site7-studio/_components/sidebar" with { selectedItem: 'sections' } only %}
{% endblock %}

{% block content %}
    <div class="site7-package-preview" style="max-width: 1000px;">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
            <h1 style="margin: 0;">Preview: {{ package.name }}</h1>
            <a href="{{ url('site7-studio/library/package/' ~ package.handle) }}" class="btn">Back to Details</a>
        </div>

        <div class="site7-card" style="padding: 24px; background: #fff; min-height: 400px;">
            {% if hasPreviewImage %}
                <div style="text-align: center;">
                    <img src="{{ url('site7-studio/library/package/' ~ package.handle ~ '/preview-image') }}" 
                         alt="Preview of {{ package.name }}" 
                         style="max-width: 100%; height: auto; border-radius: 8px; box-shadow: 0 2px 12px rgba(0,0,0,0.1);">
                </div>
            {% else %}
                <div style="text-align: center; color: #666; padding-top: 100px;">
                    <span data-icon="image" style="font-size: 48px; color: #ccc;"></span>
                    <h3 style="margin-top: 16px; color: #666;">No Preview Available</h3>
                    <p class="light">This package does not have a preview image yet.</p>
                </div>
            {% endif %}
        </div>

        {# Package info below the preview #}
        <div class="site7-card" style="padding: 24px; margin-top: 16px;">
            <table class="data fullwidth">
                <tbody>
                    <tr>
                        <th style="width: 30%;">Package</th>
                        <td>{{ package.name }}</td>
                    </tr>
                    <tr>
                        <th>Version</th>
                        <td>{{ package.version }}</td>
                    </tr>
                    <tr>
                        <th>Type</th>
                        <td>{{ package.type|title }}</td>
                    </tr>
                    <tr>
                        <th>Status</th>
                        <td><span class="site7-badge {{ package.status == 'enabled' ? 'site7-badge--active' : 'site7-badge--draft' }}">{{ package.status|title }}</span></td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}
