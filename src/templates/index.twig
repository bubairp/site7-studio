{% extends "_layouts/cp" %}
{% set title = "Dashboard" %}
{% set selectedSubnavItem = "dashboard" %}



{% block content %}
    <div class="site7-stat-grid">
        {% include "site7-studio/_components/stat-card" with { value: sectionsCount ?? 0, label: 'Installed Sections' } only %}
        {% include "site7-studio/_components/stat-card" with { value: templatesCount ?? 0, label: 'Installed Templates' } only %}
        {% include "site7-studio/_components/stat-card" with { value: version ?? '1.0.0', label: 'Version' } only %}
    </div>

    <div class="pane">
        <h2>{{ "Platform Status"|t('site7-studio') }}</h2>
        <div class="meta" style="margin-bottom: 20px;">
            <div class="data">
                <dt>{{ "Setup Status"|t('site7-studio') }}</dt>
                <dd>
                    {% if isSetupComplete %}
                        <span class="status green"></span> ✓ Setup Complete
                    {% else %}
                        <span class="status red"></span> ⚠ Setup Required
                    {% endif %}
                </dd>
            </div>
            <div class="data">
                <dt>{{ "Current Phase"|t('site7-studio') }}</dt>
                <dd>{{ currentPhase ?? 'Phase 7.0' }}</dd>
            </div>
        </div>

        {% if not isSetupComplete %}
            <div style="background: #fff3cd; color: #856404; padding: 15px; border-radius: 4px; border: 1px solid #ffeeba;">
                <strong>Warning:</strong> You must complete the First-Time Setup Wizard before you can install Site7 packages.<br><br>
                <a href="{{ url('site7-studio/setup') }}" class="btn submit">Complete Setup</a>
            </div>
        {% endif %}
    </div>

    <div class="site7-quick-actions">
        <h3>{{ "Quick Actions"|t('site7-studio') }}</h3>
        <div class="flex">
            <a href="{{ url('site7-studio/library') }}" class="btn submit">{{ "Browse Library"|t('site7-studio') }}</a>
            <a href="{{ url('site7-studio/library', {type: 'template'}) }}" class="btn">{{ "Templates"|t('site7-studio') }}</a>
            <a href="{{ url('site7-studio/settings') }}" class="btn">{{ "Settings"|t('site7-studio') }}</a>
        </div>
    </div>
{% endblock %}
