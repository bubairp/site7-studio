{% extends "_layouts/cp" %}
{% set title = "Dashboard" %}
{% set selectedSubnavItem = "dashboard" %}

{% block content %}
    <div class="site7-stat-grid">
        {% include "site7-studio/_components/stat-card" with {
            value: byType.section ?? 0,
            label: 'Sections',
            url: url('site7-studio/library', {type: 'section'}),
        } only %}
        {% include "site7-studio/_components/stat-card" with {
            value: byType.pattern ?? 0,
            label: 'Patterns',
            url: url('site7-studio/library', {type: 'pattern'}),
        } only %}
        {% include "site7-studio/_components/stat-card" with {
            value: byType.template ?? 0,
            label: 'Templates',
            url: url('site7-studio/library', {type: 'template'}),
        } only %}
        {% include "site7-studio/_components/stat-card" with {
            value: byType['starter-kit'] ?? 0,
            label: 'Starter Kits',
            url: url('site7-studio/library', {type: 'starter-kit'}),
        } only %}
    </div>

    <div class="pane">
        <h2>{{ "Platform Status"|t('site7-studio') }}</h2>
        <div class="meta">
            <div class="field">
                <div class="heading"><label>{{ "Setup Status"|t('site7-studio') }}</label></div>
                <div class="input">
                    {% if isSetupComplete %}
                        <span class="status-label green"><span class="status green"></span><span class="status-label-text">{{ "Complete"|t('site7-studio') }}</span></span>
                    {% else %}
                        <span class="status-label red"><span class="status red"></span><span class="status-label-text">{{ "Required"|t('site7-studio') }}</span></span>
                    {% endif %}
                </div>
            </div>
            <div class="field">
                <div class="heading"><label>{{ "Total Packages"|t('site7-studio') }}</label></div>
                <div class="input">{{ totalPackages ?? 0 }}</div>
            </div>
            <div class="field">
                <div class="heading"><label>{{ "Enabled"|t('site7-studio') }}</label></div>
                <div class="input">{{ byStatus.enabled ?? 0 }}</div>
            </div>
            {% if (byStatus.available ?? 0) > 0 %}
                <div class="field">
                    <div class="heading"><label>{{ "Available to Install"|t('site7-studio') }}</label></div>
                    <div class="input">{{ byStatus.available }}</div>
                </div>
            {% endif %}
            <div class="field">
                <div class="heading"><label>{{ "Plugin Version"|t('site7-studio') }}</label></div>
                <div class="input">{{ version ?? '1.0.0' }}</div>
            </div>
        </div>

        {% if not isSetupComplete %}
            <div class="site7-notice site7-notice--warning">
                <strong>{{ "Warning:"|t('site7-studio') }}</strong> {{ "You must complete the First-Time Setup Wizard before you can install Site7 packages."|t('site7-studio') }}
                <br><br>
                <a href="{{ url('site7-studio/setup') }}" class="btn submit">{{ "Complete Setup"|t('site7-studio') }}</a>
            </div>
        {% endif %}
    </div>

    <div class="site7-quick-actions">
        <h3>{{ "Quick Actions"|t('site7-studio') }}</h3>
        <div class="flex">
            <a href="{{ url('site7-studio/library') }}" class="btn submit">{{ "Browse Library"|t('site7-studio') }}</a>
            <a href="{{ url('site7-studio/library', {type: 'template'}) }}" class="btn">{{ "Templates"|t('site7-studio') }}</a>
            <a href="{{ url('site7-studio/settings') }}" class="btn">{{ "Settings"|t('site7-studio') }}</a>
        </div>
    </div>
{% endblock %}
